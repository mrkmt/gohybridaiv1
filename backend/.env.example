# =============================================================================
# GoHybridAI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to source control.
# =============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# API key for programmatic access (automation clients, webhooks)
API_KEY=your-dev-api-key-change-in-production

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
PG_USER=postgres
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=ai_testing_platform
PG_MAX_CLIENTS=20
PG_IDLE_TIMEOUT=30000
PG_CONN_TIMEOUT=2000

# ─── Application Under Test ──────────────────────────────────────────────────
# The target web application being tested (never hardcode this in source files)
BASE_URL=https://test.globalhr.com.mm/ook
CUSTOMER_ID=your_customer_id

# Test account credentials (used by Playwright login helper)
TEST_IDNUMBER=
TEST_USERNAME=
TEST_PASSWORD=

# Secondary account credentials (used for Data Isolation / Multi-Actor tests)
# Use these when a test scenario explicitly asks to verify data as another user.
TEST_IDNUMBER_SECONDARY=
TEST_USERNAME_SECONDARY=
TEST_PASSWORD_SECONDARY=

# ─── Jira ────────────────────────────────────────────────────────────────────
# Domain only — no https:// prefix, no trailing slash
# e.g. yourcompany.atlassian.net
JIRA_DOMAIN=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Account ID of QA lead for @mentions in Jira comments
JIRA_QA_LEAD_ID=

# ─── AI: OpenRouter (HTTP API — embeddings + generation fallback) ─────────────
OPENROUTER_API_KEY=
# Additional keys for automatic rate-limit rotation (optional)
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_API_KEY_4=
OPENROUTER_API_KEY_5=
OPENROUTER_API_KEY_6=
OPENROUTER_API_KEY_7=
OPENROUTER_API_KEY_8=

# ─── AI: Groq (HTTP API — secondary fallback) ────────────────────────────────
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=

# ─── AI: Gemini (REST API — direct) ─────────────────────────────────────────
GEMINI_API_KEY=

# ─── AI: CLI Tool Paths ──────────────────────────────────────────────────────
# Directory where the Gemini CLI stores its config and auth
GEMINI_PATH=~/.gemini
# Directory where the Qwen CLI stores its config
QWEN_PATH=~/.qwen
# Directory where the Codex CLI stores its config
CODEX_PATH=~/.codex

# ─── AI: Models & Routing ────────────────────────────────────────────────────
DEFAULT_AI_MODEL=qwen/qwen3.6-plus:free
FALLBACK_AI_MODEL=openai/gpt-oss-120b:free
# Timeout for all AI requests (milliseconds)
AI_TIMEOUT_MS=300000
SCRIPT_GEN_TIMEOUT_MS=300000
# "auto" = role-based routing via ai-settings.json | "manual" = use DEFAULT_AI_MODEL always
AI_MODEL_PREFERENCE=auto
ENABLE_AUTO_ROUTING=true
ENABLE_AI_FALLBACK=true

# ─── AI: Agent Profile Overrides (optional) ──────────────────────────────────
# Override the model used for a specific role (leave blank to use ai-settings.json defaults)
AGENT_PROFILE_ARCHITECT=
AGENT_PROFILE_CODER=
AGENT_PROFILE_REVIEWER=
AGENT_PROFILE_ANALYST=
AGENT_PROFILE_INVESTIGATOR=
AGENT_PROFILE_TEST_GENERATION=

# ─── AI: Unified Model (for AgentOrchestrator) ───────────────────────────────
UNIFIED_AI_MODEL=

# ─── Discovery ───────────────────────────────────────────────────────────────
# Strategy: hybrid | ai-first | source-code | extension
DISCOVERY_DEFAULT_STRATEGY=hybrid
DISCOVERY_MAX_PAGES=5
# Allow cloud AI fallback when local CLI fails during discovery
DISCOVERY_ALLOW_CLOUD_FALLBACK=false
# Comma-separated list of allowed AI models for discovery analysis
DISCOVERY_ALLOWED_MODELS=gemini,qwen

# ─── Storage ─────────────────────────────────────────────────────────────────
# Override the default local_storage path (useful for Docker volume mounts)
LOCAL_STORAGE_PATH=

# ─── API Base URL (for TemplateResolver and integration tests) ────────────────
API_BASE_URL=http://localhost:3000

# ─── Playwright Agent (emergency self-healing — disabled by default) ──────────
PLAYWRIGHT_AGENT_ENABLED=false
PLAYWRIGHT_AGENT_API_KEY=
# "anthropic" or "openrouter"
PLAYWRIGHT_AGENT_PROVIDER=openrouter
PLAYWRIGHT_AGENT_MODEL=

# ─── Jira Sync ───────────────────────────────────────────────────────────────
# Set to false to disable background Jira polling (recommended in development)
JIRA_SYNC_ENABLED=true
# Polling interval in ms (default 5 min prod, use 30 min for dev)
JIRA_SYNC_INTERVAL_MS=300000

# ─── CI / Test environment ───────────────────────────────────────────────────
# Set to true in CI/CD pipelines — suppresses interactive prompts
CI=false
# Set to true to delete test tickets created during integration tests
CLEANUP_TEST_TICKETS=false


# ─── Infrastructure ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
SENTRY_DSN=
