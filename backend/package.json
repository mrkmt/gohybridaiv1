{
  "name": "go-hybrid-ai-backend",
  "version": "1.1.0",
  "description": "Backend for AI-assisted web-automation testing platform",
  "main": "api/server.ts",
  "scripts": {
    "start": "ts-node --transpile-only --project tsconfig.json api/server.ts",
    "start:strict": "ts-node --project tsconfig.json api/server.ts",
    "dev": "nodemon --ignore test-results/ --ignore scripts/ --ignore tests/gen/ --ignore tests/generated/ --ignore local_storage/ --ignore src/local_storage/ --ignore active-tickets.json --ignore playwright-report/ --ignore reports/ --exec \"ts-node --transpile-only --project tsconfig.json\" api/server.ts",
    "typecheck": "tsc --noEmit",
    "restart": "node -e \"console.log('Restarting...'); require('child_process').exec('taskkill /F /IM node.exe', (e) => { setTimeout(() => require('child_process').spawn('npm', ['run', 'dev'], {stdio: 'inherit', shell: true}), 2000); })\"",
    "init-db": "ts-node --project tsconfig.json api/init-db.ts",
    "discovery:run": "ts-node --project tsconfig.json api/nightly-crawler.ts",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:jest": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "dns:clear": "ts-node --project tsconfig.json scripts/clear-dns-cache.ts",
    "skills:generate": "ts-node --project tsconfig.json scripts/generate-skills-from-recording.ts",
    "skills:watch": "ts-node --project tsconfig.json scripts/auto-sync-recordings.ts",
    "seed:admin": "ts-node --project tsconfig.json scripts/seed-admin-user.ts",
    "fix:selectors": "ts-node --project tsconfig.json scripts/fix-button-selectors.ts"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.12.0",
    "@google/genai": "^1.50.1",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.70",
    "@sentry/node": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@types/archiver": "^7.0.0",
    "@types/node-fetch": "^2.6.13",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "boxen": "^8.0.1",
    "bullmq": "^5.76.4",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.2",
    "finalhandler": "^2.1.1",
    "form-data": "^4.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.7",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "multer": "^2.1.0",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tesseract.js": "^7.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "uuid": "^9.0.1",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/types": "^7.29.0",
    "@playwright/test": "1.49.0",
    "@types/adm-zip": "^0.5.8",
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/form-data": "^2.2.1",
    "@types/jest": "^29.5.10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lru-cache": "^7.10.9",
    "@types/minio": "^7.1.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.10.9",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "playwright": "1.49.0",
    "playwright-core": "1.49.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1"
  }
}
