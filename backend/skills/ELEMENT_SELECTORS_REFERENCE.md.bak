### Recommended Page Object Pattern

```typescript
// pages/company_profile.page.ts
import { Page, Locator } from '@playwright/test';

export class CompanyProfilePage {
  constructor(private page: Page) {}

  // === Locators ===
  readonly master = this.page.getByText('Master', { exact: true });
  readonly companyProfile = this.page.getByText('Company Profile', { exact: true });
  readonly fax = this.page.locator('kendo-textbox[formControlName="Fax"]');
  readonly clusterid = this.page.locator('select[name="ClusterID"]');
  readonly country = this.page.locator('select[name="Country"]');
  readonly sun = this.page.getByText('Sun', { exact: true });
  readonly mon = this.page.getByText('Mon', { exact: true });
  readonly monday = this.page.locator('input[name="Monday"]');
  readonly tue = this.page.getByText('Tue', { exact: true });

  // === Actions ===

  async navigate() {
    await this.page.goto('https://www.globalhr.app/u9#/app.company');
  }

  async clickElement(selector: string) {
    await this.page.locator(selector).click();
  }

}
```

## Best Practices

### ✅ DO

```typescript
// 1. Use formControlName for form elements
await page.locator('[formControlName="Fax"]').fill('123');

// 2. Use getByRole for accessible elements
await page.getByRole('button', { name: 'Cancel' }).click();

// 3. Use getByText for visible text
await page.getByText('Company Profile', { exact: true }).click();

// 4. Use getByLabel for labeled inputs
await page.getByLabel('Country').selectOption('Myanmar');

// 5. Wait for network responses before assertions
await page.waitForResponse('**/api/company/**');

// 6. Use data-testid when available
// (Request dev team to add these to critical elements)

// 7. Use waitForSelector before interacting with async-loaded elements
await page.waitForSelector('.result-table');
await page.locator('.result-table').click();
```

### ❌ DON'T

```typescript
// 1. Avoid Kendo-generated IDs (they change between sessions)
// BAD:
await page.locator('#k-c0f62757-529e-4a44-a7da-ca17a6120222').click();

// 2. Avoid deeply nested nth-child selectors (brittle)
// BAD:
await page.locator('div > div.row:nth-child(6) > div.col-md-6:nth-child(1)').click();

// 3. Don't skip waits for async operations
// BAD:
await page.locator('button').click();
await page.locator('.result').click(); // May fail if not loaded

// GOOD:
await page.locator('button').click();
await page.waitForSelector('.result');
await page.locator('.result').click();

// 4. Don't use Angular/Kendo state classes
// BAD (classes change based on form state):
await page.locator('.ng-untouched.ng-pristine.ng-valid').click();

// GOOD (use stable attributes):
await page.locator('[formControlName="fieldName"]').click();
```

### Selector Stability Ranking

| Approach | Stability | Maintainability | Recommended |
|----------|-----------|-----------------|-------------|
| `data-testid` | Very High | Very High | ✅ Always (request from devs) |
| `getByRole` | High | High | ✅ Prefer |
| `formControlName` | High | High | ✅ Prefer for forms |
| `id` (static) | High | High | ✅ Prefer |
| `name` attribute | Medium | Medium | ⚠️ Acceptable |
| CSS classes | Low | Medium | ⚠️ Use cautiously |
| nth-child chains | Very Low | Low | ❌ Avoid |
| Kendo IDs | None | None | ❌ Never |

---

## Notes

- **Kendo UI IDs** (e.g., `#k-xxxx`) are dynamically generated and should be avoided in production tests
- **Angular class names** like `ng-untouched`, `ng-pristine`, `ng-valid` may change based on form state
- **nth-child selectors** are fragile and may break if DOM structure changes
- Consider requesting the dev team to add `data-testid` attributes for stable selectors
- **Regenerate this file** after significant UI changes by re-running the crawler

