    /**
     * POST /api/testing/:ticketId/generate
     * Intelligent test generation that detects Bug vs Story and routes accordingly
     */
    static async generateTestCase(req: Request, res: Response): Promise<void> {
        try {
            const { ticketId } = req.params;
            const { model, refresh = false } = req.body;
            const userId = this.getUserId(req);

            let session = await TestSessionCacheService.getSession(ticketId, userId);
            if (session && session.testCases.length > 0 && !refresh) {
                res.json({ success: true, message: 'Test cases already generated', testCases: session.testCases, fromCache: true });
                return;
            }

            // Type-aware generation — with user scenario context
            let typeAwareResult;
            const userScenariosForGenerate = session?.userScenarios?.filter(s => s.selected).map(s => s.description) || [];
            if (userScenariosForGenerate.length > 0) {
                typeAwareResult = await TestCaseGeneratorService.generateFromTicketType(ticketId, userScenariosForGenerate);
            } else {
                typeAwareResult = await TestCaseGeneratorService.generateFromTicketType(ticketId);
            }

            if (typeAwareResult.ticketType === 'Bug' && !typeAwareResult.success) {
                // Duplicate bug — return analysis info
                res.json({
                    success: false,
                    ticketType: 'Bug',
                    warning: `Potential duplicate bug detected${typeAwareResult.analysis?.duplicateTicket ? ` — similar to ${typeAwareResult.analysis.duplicateTicket} (${Math.round((typeAwareResult.analysis?.duplicateTicket ? 1 : 0) * 100)}% similar)` : ''}`,
                    analysis: typeAwareResult.analysis,
                });
                return;
            }

            // Cache the test cases
            if (!session) {
                const { JiraService } = require('../../api/JiraService');
                const ticket = await JiraService.fetchTicket(ticketId);
                const comments = ticket.comments?.map((c: any) => `[${c.author}] ${c.body}`) || [];

                session = await TestSessionCacheService.createSession(
                    ticketId, userId,
                    ticket.summary || '',
                    ticket.description || '',
                    ticket.status || 'Unknown',
                    comments
                );
            }

            const testCases = typeAwareResult.generatedTestCases?.testCases || [];
            const compiledScripts = typeAwareResult.generatedTestCases?.compiledScripts;
            // Wire linkedRequirement from user scenarios
            const selectedUserScenarios = session.userScenarios?.filter(s => s.selected) || [];
            for (const tc of testCases) {
                tc.linkedRequirement = ticketId;
                for (const scenario of selectedUserScenarios) {
                    if (scenario.description.toLowerCase().split(' ').some(word =>
                        word.length > 3 && (tc.title.toLowerCase().includes(word) || (tc.description?.toLowerCase().includes(word)))
                    )) {
                        tc.linkedRequirement = `${ticketId} — ${scenario.description.substring(0, 80)}`;
                        break;
                    }
                }
            }
            await TestSessionCacheService.updateSession(ticketId, userId, {
                testCases,
                compiledScripts,
                phase: 'test_case_design'
            });

            await this.audit(req, 'generate_cases_type_aware', 'test_session', ticketId, {
                count: testCases.length,
                ticketType: typeAwareResult.ticketType,
                module: typeAwareResult.module,
            });

            res.json({
                success: true,
                ticketType: typeAwareResult.ticketType,
                module: typeAwareResult.module,
                message: `Generated ${testCases.length} test case(s) for ${typeAwareResult.ticketType} ticket`,
                testCases,
                analysis: typeAwareResult.analysis,
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Intelligent generation error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * POST /api/testing/:ticketId/orchestrate
     */
    static async orchestrateTicket(req: Request, res: Response): Promise<void> {
        try {
            const { ticketId } = req.params;
            const { authHeaders } = req.body; // Optional: auth headers for menu API
            if (!ticketId || !ChatMentionService.validateTicketFormat(ticketId)) {
                res.status(400).json({ error: 'Invalid ticket ID format' });
                return;
            }
            const result = await JiraTicketOrchestrator.orchestrate(ticketId);

            // Attempt menu discovery if auth headers provided
            let menuDiscoveryResult: any = null;
            if (authHeaders && result.mainTicket) {
                try {
                    const baseUrl = process.env.BASE_URL || '';
                    menuDiscoveryResult = await MenuDiscoveryService.discoverWithAuthHeaders(baseUrl, authHeaders);
                    appLogger.info('[TestingWorkflow] Menu discovery completed', {
                        ticketId,
                        matched: menuDiscoveryResult.matchedModules,
                    });
                } catch (menuError: any) {
                    appLogger.warn('[TestingWorkflow] Menu discovery failed (non-critical)', {
                        ticketId,
                        error: menuError.message,
                    });
                }
            }

            res.json({ success: true, ...result, menuDiscovery: menuDiscoveryResult });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Orchestration error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * POST /api/testing/:ticketId/auto-generate
     * Full AI Brain Engine flow with confidence scoring:
     * auto-discovers page elements, generates Playwright scripts with real
     * selectors, and returns risk assessment for operator review.
     * Jira ticket → cache check → auto-discovery (if stale) → script gen → session save
     */
    static async autoGenerateTicket(req: Request, res: Response): Promise<void> {
        try {
            const { ticketId } = req.params;
            const userId = this.getUserId(req);
            const forceRegen = req.query.refresh === 'true';

            // Check if already generated in this session
            let session = await TestSessionCacheService.getSession(ticketId, userId);
            if (!forceRegen && session && (session.testCases?.length > 0 || session.compiledScripts)) {
                res.json({
                    success: true,
                    message: 'Test cases already generated (use ?refresh=true to regenerate)',
                    testCases: session.testCases,
                    compiledScripts: session.compiledScripts,
                    confidenceAssessment: session.confidenceAssessment,
                    fromCache: true
                });
                return;
            }

            // Fetch ticket from Jira
            const jiraAxios = getJiraAxios();
            const response = await jiraAxios.get(`/rest/api/3/issue/${ticketId}`, {
                params: { fields: 'summary,description,issuetype,comment,labels' }
            });

            const issue = response.data;
            const jiraIssue = {
                issueType: issue.fields.issuetype?.name || 'Unknown',
                summary: issue.fields.summary || '',
                description: TestCaseGeneratorService.extractTextFromADF(issue.fields.description) || '',
                comments: issue.fields.comment?.comments?.map((c: any) => c.body).join('\n---\n') || '',
            };

            appLogger.info(`[TestingWorkflow] Auto-generate for ${ticketId}: ${jiraIssue.issueType} — ${jiraIssue.summary}`, {
                source: 'TestingWorkflow',
                ticketId,
            });

            // Process through AIBrainEngine with confidence scoring
            const { AIBrainEngine } = await import('../engine/AIBrainEngine');
            const brainEngine = new AIBrainEngine(this.pool!);
            const result = await brainEngine.processJiraIssueWithConfidence(jiraIssue);

            appLogger.info(`[TestingWorkflow] Confidence: ${(result.confidence.overall * 100).toFixed(0)}%, Risk: ${result.riskLevel}`, {
                source: 'TestingWorkflow',
                ticketId,
                confidence: result.confidence,
                riskLevel: result.riskLevel,
                requiresReview: result.requiresManualReview,
            });

            // Generate test cases via the standard pipeline for UI compatibility
            let testCases: TestCase[];
            try {
                const userScenarios = session?.userScenarios?.filter(s => s.selected).map(s => s.description) || [];
                const genResult = await TestCaseGeneratorService.generateFromTicketType(ticketId, userScenarios);
                testCases = genResult.generatedTestCases?.testCases || [];
            } catch (err: any) {
                appLogger.warn(`[TestingWorkflow] TestCaseGeneratorService failed, using AI-generated script: ${err.message}`);
                testCases = [{
                    caseId: 'AUTO-001',
                    title: `AI Generated Test for ${ticketId}`,
                    description: jiraIssue.summary,
                    priority: 'High',
                    steps: [{
                        stepNumber: 1,
                        action: `Run AI-generated script for ticket ${ticketId}`,
                        expectedResult: 'Script completes successfully',
                    }],
                    expectedOutcome: 'AI-generated script executes without errors',
                    preconditions: [],
                    isEditable: false,
                }];
            }

            // Create session if not exists
            if (!session) {
                session = await TestSessionCacheService.createSession(
                    ticketId, userId, jiraIssue.summary, jiraIssue.description
                );
            }

            // Update session with generated content AND confidence assessment
            // Extract the code from the assessment to keep it lean (code lives in compiledScripts)
            const { code: _, ...confidenceData } = result;
            await TestSessionCacheService.updateSession(ticketId, userId, {
                testCases,
                compiledScripts: { ...(session?.compiledScripts || {}), 'ai-generated': result.code },
                confidenceAssessment: { ...confidenceData, assessedAt: new Date().toISOString() },
                phase: 'test_case_design',
            });

            await this.audit(req, 'auto_generate_with_discovery', 'test_session', ticketId, {
                count: testCases.length,
                aiGenerated: true,
                confidence: result.confidence.overall,
                riskLevel: result.riskLevel,
                requiresReview: result.requiresManualReview,
            });

            res.json({
                success: true,
                message: `Generated tests with real element selectors for ${ticketId}`,
                testCases,
                aiGeneratedScript: result.code.slice(0, 2000) + (result.code.length > 2000 ? '...' : ''),
                aiGeneratedFullScript: result.code,
                confidenceAssessment: {
                    overall: result.confidence.overall,
                    riskLevel: result.riskLevel,
                    requiresManualReview: result.requiresManualReview,
                    breakdown: result.confidence,
                    recommendations: result.recommendations,
                },
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Auto-generate error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * GET /api/testing/:ticketId/refresh
     * Queries Jira in real-time and returns AI-guided status assessment with options.
     */
    static async refreshTicket(req: Request, res: Response): Promise<void> {
        try {
            const { ticketId } = req.params;
            if (!ticketId || !ChatMentionService.validateTicketFormat(ticketId)) {
                res.status(400).json({ error: 'Invalid ticket ID format' });
                return;
            }

            const userId = this.getUserId(req);

            // Step 1: Check if ticket exists in Jira
            let jiraIssue: any;
            try {
                const jiraAxios = getJiraAxios();
                const response = await jiraAxios.get(`/rest/api/3/issue/${ticketId}`, {
                    params: { fields: 'summary,description,status,issuetype' }
                });
                jiraIssue = response.data;
            } catch (jiraErr: any) {
                // Ticket not found in Jira
                res.json({
                    success: true,
                    ticketId,
                    ticketFound: false,
                    status: 'not_found',
                    message: `⚠️ Ticket "${ticketId}" not found in Jira. Please check the ticket ID and try again.`,
                    options: [],
                    recommendation: 'Verify the ticket ID is correct. Testing requires a valid Jira ticket.',
                });
                return;
            }

            const fields = jiraIssue.fields || {};
            const issueType = fields.issuetype?.name || 'Unknown';
            const currentStatus = fields.status?.name || 'Unknown';
            const summary = fields.summary || '';
            const description = TestCaseGeneratorService.extractTextFromADF(fields.description) || '';
            const statusLower = currentStatus.toLowerCase();

            // Step 2: Check if ticket type is valid for testing
            const testingTypes = ['Bug', 'Story', 'Task']; // broad: allow Task
            const isTestingType = testingTypes.some(t => issueType.toLowerCase() === t.toLowerCase());

            if (!isTestingType) {
                res.json({
                    success: true,
                    ticketId,
                    ticketFound: true,
                    ticketType: issueType,
                    status: currentStatus,
                    summary,
                    message: `❌ "${ticketId}" is a **${issueType}**, not a Bug/Story ticket. Testing is only supported for Bug and Story tickets. Please make sure you typed a valid testing ticket.`,
                    options: [],
                    recommendation: 'Check the ticket type in Jira. Only Bug and Story tickets can be tested.',
                    blocked: true,
                });
                return;
            }

            // Step 3: Check for existing session & results
            const existingSession = await TestSessionCacheService.getSession(ticketId, userId);
            const lastRunInfo = await TestSessionCacheService.getLastRunInfo(ticketId, userId);

            // Step 4: Detect content drift
            const summaryChanged = !!(existingSession && existingSession.jiraSnapshot && existingSession.jiraSnapshot.summary !== summary);
            const descriptionChanged = !!(existingSession && existingSession.jiraSnapshot && existingSession.jiraSnapshot.description !== description);

            const buildResponse = (statusCategory: string, message: string, options: any[], recommendation: string) => ({
                success: true,
                ticketId,
                ticketFound: true,
                ticketType: issueType,
                status: currentStatus,
                statusCategory,
                summary,
                message,
                options,
                recommendation,
                hasSession: !!existingSession,
                hasResults: !!lastRunInfo && lastRunInfo.hasResults,
                lastRunAt: lastRunInfo?.lastRunAt,
                lastRunSummary: lastRunInfo?.lastSummary,
                syncRequired: summaryChanged || descriptionChanged,
                changesDetected: {
                    summaryChanged,
                    descriptionChanged,
                    previousSummary: existingSession?.jiraSnapshot?.summary,
                    currentSummary: summary,
                },
            });

            // Step 5: Determine response based on Jira status
            const isDone = statusLower.includes('done') || statusLower.includes('closed') || statusLower.includes('resolved');
            const isTesting = statusLower.includes('testing') || statusLower.includes('qa') || statusLower === 'in progress';
            const isTodo = statusLower.includes('to do') || statusLower.includes('backlog') || statusLower.includes('open') || statusLower.includes('new');

            if (isDone) {
                // === DONE / BUG DONE ===
                const wasTestedBefore = lastRunInfo?.hasResults;
                res.json(buildResponse('done',
                    `✅ "${ticketId}" is marked **${currentStatus}**. Testing is already complete for this ticket. You cannot restart testing. Need a new ticket or manually reopen the ticket in Jira.`,
                    [],
                    wasTestedBefore
                        ? `Last execution: ${lastRunInfo.lastRunAt}. Results: ${lastRunInfo.lastSummary!.passed}/${lastRunInfo.lastSummary!.total} passed. Archive available via DELETE /:ticketId/session if needed.`
                        : 'No previous testing record found for this ticket.'
                ));
                return;
            }

            if (isTesting) {
                // === IN TESTING / QA ===
                if (!existingSession && !lastRunInfo) {
                    // No session, no results — fresh start
                    res.json(buildResponse('in_testing',
                        `🚀 "${ticketId}" is in **${currentStatus}**. Ready to begin testing. This will auto-transition the ticket if needed and create a new test session.`,
                        [
                            { action: 'start', label: 'Start Testing', endpoint: `POST /api/testing/${ticketId}/start` },
                            { action: 'cancel', label: 'Cancel', endpoint: null },
                        ],
                        'Call start endpoint to begin the testing pipeline.'
                    ));
                    return;
                }

                if (lastRunInfo && lastRunInfo.hasResults && summaryChanged) {
                    // Has results but content CHANGED significantly
                    res.json(buildResponse('in_testing_changed',
                        `⚠️ "${ticketId}" was previously tested. Last run: **${lastRunInfo.lastRunAt}**. Results: **${lastRunInfo.lastSummary!.passed}/${lastRunInfo.lastSummary!.total} passed**.\n\n**Jira content has changed** since last test run!\nPrevious: "${existingSession?.jiraSnapshot?.summary}"\nCurrent:  "${summary}"\n\nPrevious test results may be stale.`,
                        [
                            { action: 'restart', label: 'Restart (Recommended)', endpoint: `DELETE /api/testing/${ticketId}/session then POST /api/testing/${ticketId}/start` },
                            { action: 'continue', label: 'Continue (re-run current tests)', endpoint: `POST /api/testing/${ticketId}/execute` },
                            { action: 'exit', label: 'Exit (view only)', endpoint: null },
                        ],
                        'Content change detected. Recommended to restart testing with fresh test generation.'
                    ));
                    return;
                }

                if (lastRunInfo && lastRunInfo.hasResults) {
                    // Has results, NO content change
                    res.json(buildResponse('in_testing_synced',
                        `✅ "${ticketId}" is in **${currentStatus}**. Last tested: **${lastRunInfo.lastRunAt}**. Results: **${lastRunInfo.lastSummary!.passed}/${lastRunInfo.lastSummary!.total} passed**. Content is unchanged.`,
                        [
                            { action: 'retry_failed', label: 'Retry failed only', endpoint: `POST /api/testing/${ticketId}/execute/retry` },
                            { action: 'rerun', label: 'Full re-run', endpoint: `POST /api/testing/${ticketId}/execute` },
                            { action: 'view', label: 'View results only', endpoint: `GET /api/testing/${ticketId}/session` },
                            { action: 'exit', label: 'Exit', endpoint: null },
                        ],
                        'Tests were successful. Choose to retry failures, re-run all, or just view.'
                    ));
                    return;
                }

                // Has session but no results (started but not executed yet)
                if (!lastRunInfo || !lastRunInfo.hasResults) {
                    res.json(buildResponse('in_testing_partial',
                        `"${ticketId}" has a session but no completed test runs. Current phase: **${existingSession?.phase}**.`,
                        [
                            { action: 'continue', label: 'Continue from current phase', endpoint: `POST /api/testing/${ticketId}/${existingSession?.phase === 'test_case_design' ? 'test-cases/generate' : 'execute'}` },
                            { action: 'restart', label: 'Restart from scratch', endpoint: `DELETE /api/testing/${ticketId}/session then POST /api/testing/${ticketId}/start` },
                            { action: 'cancel', label: 'Cancel session', endpoint: `POST /api/testing/${ticketId}/cancel` },
                        ],
                        'Session exists but tests not run yet. Continue or restart?'
                    ));
                    return;
                }

                res.json(buildResponse('in_testing_fallback',
                    `"${ticketId}" is in **${currentStatus}**.`,
                    [
                        { action: 'start', label: 'Start Testing', endpoint: `POST /api/testing/${ticketId}/start` },
                    ],
                    ''
                ));
                return;
            }

            if (isTodo) {
                res.json(buildResponse('to_do',
                    `📋 "${ticketId}" is in **${currentStatus}**. Ready for testing. This will auto-transition to In Testing and create a new test session.`,
                    [
                        { action: 'start', label: 'Start Testing', endpoint: `POST /api/testing/${ticketId}/start` },
                        { action: 'cancel', label: 'Cancel', endpoint: null },
                    ],
                    'Call /start to begin the testing pipeline: transition → scenario gen → test case design → execution.'
                ));
                return;
            }

            // Unknown / Other status
            res.json(buildResponse('other',
                `📌 "${ticketId}" is in **${currentStatus}**. This status is not standard for the testing pipeline. Recommend moving to "In Testing" first for proper tracking.`,
                [
                    { action: 'start', label: 'Start Testing (with auto-transition)', endpoint: `POST /api/testing/${ticketId}/start` },
                    { action: 'cancel', label: 'Cancel', endpoint: null },
                ],
                'Unusual status. Testing can still start (auto-transition handles this).'
            ));

        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Refresh error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * GET /api/testing/sessions/cleanup
     * Clean up stale sessions older than maxAgeHours.
     */
    static async cleanupSessions(req: Request, res: Response): Promise<void> {
        try {
            const maxAgeHours = parseInt(req.query.maxAgeHours as string) || 24;
            const cleaned = await TestSessionCacheService.cleanupStaleSessions(maxAgeHours);
            res.json({
                success: true,
                cleaned,
                message: `Cleaned up ${cleaned} stale session(s) older than ${maxAgeHours} hours.`,
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Session cleanup error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * POST /api/testing/discover
     * Discover all UI elements on a specific page.
     * Body: { hashRoute: "#/app.designation", moduleName: "Designation", deepScan: false }
     */
    static async discoverPage(req: Request, res: Response): Promise<void> {
        try {
            const { hashRoute, moduleName, deepScan = false } = req.body;

            if (!hashRoute || !moduleName) {
                res.status(400).json({
                    error: 'Missing required fields: hashRoute and moduleName',
                    example: { hashRoute: '#/app.designation', moduleName: 'Designation', deepScan: false },
                });
                return;
            }

            appLogger.info(`[TestingWorkflow] Discover: ${moduleName} (${hashRoute})`, {
                source: 'TestingWorkflow',
                module: moduleName,
                route: hashRoute,
                deepScan,
            });

            const { discoverSinglePage } = await import('../../scripts/discover-page');
            const { FrontendTechnologyDetector } = await import('../services/FrontendTechnologyDetector');
            const { UniversalPageModelService } = await import('../services/UniversalPageModelService');

            // Emit discovery start
            ProcessProgressService.discoveryProgress(moduleName || hashRoute,
                `Starting page discovery for ${moduleName} (${hashRoute})...`,
                20);

            const inventory = await discoverSinglePage(hashRoute, moduleName, {
                deepScan,
                headless: true,
            });
            if (!inventory) {
                ProcessProgressService.failed(moduleName || hashRoute,
                    'Page discovery returned no inventory');
                res.status(502).json({
                    error: 'Page discovery returned no inventory',
                    hint: 'Ensure the target page loaded successfully and discovery did not fail silently.',
                });
                return;
            }

            // Emit discovery mid-point
            const elementCount = inventory.buttons.length + inventory.inputs.length +
                inventory.dropdowns.length + inventory.grids.length + inventory.modals.length + inventory.tabs.length;
            ProcessProgressService.discoveryProgress(moduleName || hashRoute,
                `Discovered ${elementCount} elements, analyzing technology profile...`,
                60,
                { elementCount });

            const pageModel = await UniversalPageModelService.buildEnhanced(inventory);
            const technologyReport = pageModel.technologies;

            // Emit discovery completion with technology profile
            ProcessProgressService.discoveryProgress(moduleName || hashRoute,
                `Discovery complete: Primary technology = ${technologyReport.primary}, ${pageModel.elements.length} actionable elements`,
                100,
                {
                    technologyProfile: {
                        primary: technologyReport.primary,
                        detected: technologyReport.detected.map(t => ({ technology: t.technology, confidence: t.confidence })),
                    },
                    elementCount: pageModel.elements.length,
                });

            await res.json({
                success: true,
                moduleName,
                hashRoute,
                inventory,
                technologyReport,
                pageModel,
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Page discovery error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message, hint: 'Ensure the test site is accessible and baseline credentials are valid.' });
        }
    }

    /**
     * GET /api/testing/discover/all
     * Discover elements on all known modules.
     * Query: ?deepScan=true
     */
    static async discoverAllModules(req: Request, res: Response): Promise<void> {
        try {
            const deepScan = req.query.deepScan === 'true';

            res.json({
                status: 'started',
                message: 'Full module discovery started. This may take several minutes.',
                deepScan,
            });

            // Run discovery in background, results saved to repository + files
            // Use setImmediate to not block the response
            setImmediate(async () => {
                try {
                    const { discoverAllModules: runDiscovery } = await import('../../scripts/discover-page');
                    const results = await runDiscovery(deepScan);

                    const summary = results.map(r => ({
                        moduleName: r.moduleName,
                        hashRoute: r.hashRoute,
                        elementCount: r.inventory ? (
                            r.inventory.buttons.length +
                            r.inventory.inputs.length +
                            r.inventory.dropdowns.length +
                            r.inventory.grids.length +
                            r.inventory.tabs.length +
                            r.inventory.modals.length +
                            r.inventory.checkboxes.length +
                            r.inventory.radios.length +
                            r.inventory.other.length
                        ) : 0,
                        summary: r.inventory?.summary || 'FAILED',
                        error: r.error || null,
                    }));

                    appLogger.info('[TestingWorkflow] Full discovery complete', {
                        source: 'TestingWorkflow',
                        modules: results.length,
                        failed: results.filter(r => r.error).length,
                        summary,
                    });
                } catch (err: any) {
                    appLogger.error('[TestingWorkflow] Full discovery error', {
                        source: 'TestingWorkflow',
                        error: err.message,
                    });
                }
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Discover all modules error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }

    /**
     * GET /api/testing/:ticketId/confidence
     * Returns the AI confidence assessment for the current test generation session.
     * Provides risk level, breakdown by pipeline stage, and actionable recommendations.
     */
    static async getConfidenceAssessment(req: Request, res: Response): Promise<void> {
        try {
            const { ticketId } = req.params;
            const userId = this.getUserId(req);

            const session = await TestSessionCacheService.getSession(ticketId, userId);
            if (!session) {
                res.status(404).json({
                    success: false,
                    message: `No session found for ticket ${ticketId}`,
                });
                return;
            }

            if (!session.confidenceAssessment) {
                res.json({
                    success: true,
                    message: 'No confidence assessment available (tests not generated via AI pipeline)',
                    hasAssessment: false,
                });
                return;
            }

            res.json({
                success: true,
                hasAssessment: true,
                assessment: session.confidenceAssessment,
            });
        } catch (error: any) {
            appLogger.error('[TestingWorkflow] Get confidence assessment error', { source: 'TestingWorkflow', error: error.message });
            res.status(500).json({ error: error.message });
        }
    }
}
